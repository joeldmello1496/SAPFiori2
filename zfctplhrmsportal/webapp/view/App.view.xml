<mvc:View controllerName="zfctplhrmsportal.controller.App"
    xmlns:html="http://www.w3.org/1999/xhtml"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt">
    <App id="app" initialPage="splitApp">
        <SplitApp id="splitApp"  >
            <masterPages     >
                <Page showHeader="true" title="Master Page" id="masterPage"  >
                    <customHeader>
                        <Bar>
                            <contentLeft>
                                <Image width="50px" id="SideBarHeaderLogo" src="{/svgLogo}" tooltip="Castaliaz Technologies Pvt Ltd"  />
                            </contentLeft>

                            <contentMiddle>
                                <Text class="ClassTextBolder" id="SideBarHeaderCName" text="Castaliaz Technologies Pvt Ltd"/>
                                <Button press="OnClick" tooltip="Expand/Collapse Side Bar" icon="sap-icon://menu2"/>
                            </contentMiddle>

                            
                            
                        </Bar>
                    </customHeader>
                    <content>
                        <tnt:SideNavigation visible="true" width="330px"  id="sideNavigation">
                            <tnt:NavigationList  id="navigationList" >
                                <tnt:NavigationListItem id="idSelfService" visible="true" text="Self Service" select=".OnExpandItems" icon="sap-icon://home" expanded="false">
                                    <tnt:NavigationListItem id="idView" visible="true" key="Selfservice.View.View" text="View" select=".OnNavBtn" icon="" expanded="false"/>
                                    <tnt:NavigationListItem id="idEdit" visible="true" key="Selfservice.Edit.Edit" text="Edit" select=".OnNavBtn" icon="" expanded="false"/>
                                    <tnt:NavigationListItem id="idSalary" visible="true" key="Selfservice.Salary.Salary" text="Salary" select=".OnNavBtn" icon="" expanded="false"/>
                                    <tnt:NavigationListItem id="idTaxation" visible="true" key="Selfservice.Taxation.Taxation" text="Taxation" select=".OnNavBtn" icon="" expanded="false"/>
                                    <tnt:NavigationListItem id="idQuickInfo" visible="true" key="Selfservice.QuickInfo.QuickInfo" text="Quick Info" select=".OnNavBtn" icon="" expanded="false"/>
                                    <tnt:NavigationListItem id="idWorkFlow" visible="true" key="Selfservice.WorkFlow.WorkFlow" text="Work Flow" select=".OnNavBtn" icon="" expanded="false"/>
                                </tnt:NavigationListItem>
                                <tnt:NavigationListItem id="idLeave" visible="true" text="Leave" select=".OnExpandItems" icon="sap-icon://write-new-document" expanded="false">
                                    <tnt:NavigationListItem id="idMyInfo" visible="true" key="Leave.MyInfo.MyInfo" text="My Info" select=".OnNavBtn" icon="" expanded="false"/>
                                    <tnt:NavigationListItem id="idLeavePlanner" visible="true" key="Leave.LeavePlanner.LeavePlanner" text="Leave Planner" select=".OnNavBtn" icon="" expanded="false"/>
                                    <tnt:NavigationListItem id="idApplyLeave" visible="true" key="Leave.ApplyLeave.ApplyLeave" text="Apply Leave" select=".OnNavBtn" icon="" expanded="false"/>
                                    <tnt:NavigationListItem id="idOutDoorDuty" visible="true" key="Leave.OutDoorDuty.OutDoorDuty" text="Out Door Duty" select=".OnNavBtn" icon="" expanded="false"/>
                                    <tnt:NavigationListItem id="idCompOff" visible="true" key="Leave.CompOff.CompOff" text="Comp Off" select=".OnNavBtn" icon="" expanded="false"/>
                                    <tnt:NavigationListItem id="idLeaveAdjustment" key="Leave.LeaveAdjustment.LeaveAdjustment" visible="true" text="Leave Adjustment" select=".OnNavBtn" icon="" expanded="false"/>
                                </tnt:NavigationListItem>
                                <tnt:NavigationListItem id="idTime" visible="true" text="Time" select=".OnExpandItems" icon="sap-icon://customer-history" expanded="false">
                                    <tnt:NavigationListItem id="idAttendance" key="Time.Attendance.Attendance" visible="true" text="Attendance" select=".OnNavBtn" icon="" expanded="false"/>
                                    <tnt:NavigationListItem id="idSwipe" key="Time.Swipe.Swipe" visible="true" text="Swipe" select=".OnNavBtn" icon="" expanded="false"/>
                                    <tnt:NavigationListItem id="idShortTimeOff" key="Time.ShortTimeOff.ShortTimeOff" visible="true" text="Short Time Off" select=".OnNavBtn" icon="" expanded="false"/>
                                </tnt:NavigationListItem>
                                <tnt:NavigationListItem id="idClaims" visible="true" text="Claims" select=".OnExpandItems" icon="sap-icon://high-priority" expanded="false">
                                    <tnt:NavigationListItem id="idExpense" visible="true" key="Claims.Expense.Expense" text="Expense" select=".OnNavBtn" icon="" expanded="false"/>
                                </tnt:NavigationListItem>
                                <tnt:NavigationListItem id="idRecruitment" visible="true" text="Recruitment" select=".OnExpandItems" icon="sap-icon://employee-lookup" expanded="false">
                                    <tnt:NavigationListItem id="idRecruit" visible="true" key="Recruitment.Recruit.Recruit" text="Recruit" select=".OnNavBtn" icon="" expanded="false"/>
                                </tnt:NavigationListItem>
                            </tnt:NavigationList>
                        </tnt:SideNavigation>
                    </content>
                </Page>
            </masterPages>
            <detailPages>
                 <mvc:XMLView viewName="zfctplhrmsportal.view.Home" />
            </detailPages>
        </SplitApp>
    </App>
</mvc:View>
